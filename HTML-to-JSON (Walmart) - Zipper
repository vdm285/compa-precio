import os
import zipfile

def zip_product_jsons(output_filename='productos_extraidos.zip'):
    content_dir = '/content/'
    summary_file = '_resumen_extraccion.json'

    # Get all JSON files except the summary
    files_to_zip = [
        f for f in os.listdir(content_dir)
        if f.endswith('.json') and f != summary_file
    ]

    if not files_to_zip:
        print("⚠️ No product JSON files found to zip.")
        return

    with zipfile.ZipFile(os.path.join(content_dir, output_filename), 'w') as zipf:
        for file in files_to_zip:
            zipf.write(os.path.join(content_dir, file), file)
            print(f"📦 Added to zip: {file}")

    print(f"\n✅ Success! All products zipped into: {output_filename}")
    print(f"📄 The summary file '{summary_file}' was kept separate.")

zip_product_jsons()
