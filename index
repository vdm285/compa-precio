<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Comparador CDMX - Vista Tienda</title>
    <!-- [FILOSOFÍA] Uso de Tailwind via CDN para prototipado rápido sin dependencias locales pesadas -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <style>
        /* Estilos base para los toggles (interruptores) */
        .toggle-checkbox:checked { right: 0; border-color: #10B981; }
        .toggle-checkbox:checked + .toggle-label { background-color: #10B981; }
        .toggle-checkbox { right: 0; z-index: 1; border-color: #E5E7EB; transition: all 0.3s; }
        .toggle-label { width: 2.5rem; height: 1.25rem; background-color: #E5E7EB; border-radius: 9999px; transition: all 0.3s; }
        
        /* Animaciones para los Modales */
        .modal-enter { transform: translateY(100%); opacity: 0; }
        .modal-enter-active { transform: translateY(0); opacity: 1; transition: all 0.2s ease-out; }
        .modal-leave { transform: translateY(0); opacity: 1; }
        .modal-leave-active { transform: translateY(100%); opacity: 0; transition: all 0.2s ease-in; }
        
        /* Ocultar scrollbars para look de app nativa */
        ::-webkit-scrollbar { width: 0px; background: transparent; }
    </style>
</head>
<body class="bg-gray-100 text-gray-800 font-sans h-screen flex justify-center">

    <div class="w-full max-w-md bg-white h-full relative flex flex-col shadow-2xl overflow-hidden">
        
        <!-- ========================================== -->
        <!-- HEADER STICKY -->
        <!-- ========================================== -->
        <header class="sticky top-0 z-40 bg-white border-b shadow-sm pt-4 px-4 pb-3 flex flex-col gap-3">
            <div class="flex justify-between items-center">
                <!-- Selector de Ubicación (Placeholder) -->
                <div class="flex flex-col cursor-pointer group" onclick="abrirModalUbicacion()">
                    <span class="text-[10px] font-semibold text-gray-400 uppercase tracking-wider group-hover:text-indigo-500 transition flex items-center gap-1">
                        CP: 01210 <i class="ph ph-caret-down"></i>
                    </span>
                    <h1 class="text-lg font-bold text-indigo-700 leading-tight flex items-center gap-1">
                        <i class="ph ph-storefront"></i> Walmart Patio Sta Fe
                    </h1>
                </div>
                <div class="flex gap-1">
                    <button onclick="toggleImagenes()" class="p-2 text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-full transition" id="btn-toggle-img">
                        <i class="ph ph-image text-xl"></i>
                    </button>
                    <!-- Menú Hamburguesa Placeholder -->
                    <button onclick="alert('Menú de configuración avanzada próximamente.')" class="p-2 text-gray-600 hover:bg-gray-100 rounded-full transition">
                        <i class="ph ph-list text-2xl"></i>
                    </button>
                </div>
            </div>

            <div class="relative">
                <i class="ph ph-magnifying-glass absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400 text-lg"></i>
                <input type="text" id="buscador" placeholder="Buscar producto en esta tienda..." 
                       class="w-full bg-gray-100 text-sm text-gray-700 rounded-full py-2 pl-10 pr-4 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition">
            </div>
            
            <!-- CONTROLES COMPACTOS EN UNA SOLA LÍNEA -->
            <div class="flex items-center justify-between mt-1 pt-1">
                <!-- Toggle 1: Métrica -->
                <div class="flex items-center space-x-1.5">
                    <span class="text-[10px] font-bold text-indigo-600" id="label-etiqueta">Etiqueta</span>
                    <div class="relative inline-block w-10 align-middle select-none">
                        <input type="checkbox" id="price-toggle" class="toggle-checkbox absolute block w-5 h-5 rounded-full bg-white border-4 appearance-none cursor-pointer"/>
                        <label for="price-toggle" class="toggle-label block overflow-hidden h-5 rounded-full bg-gray-300 cursor-pointer"></label>
                    </div>
                    <span class="text-[10px] font-medium text-gray-400" id="label-unidad">x100g/ml</span>
                </div>
                
                <div class="h-4 w-px bg-gray-200"></div> <!-- Separador visual -->

                <!-- Toggle 2: Comparativa -->
                <div class="flex items-center space-x-1.5">
                    <span class="text-[10px] font-bold text-indigo-600" id="label-comp-promedio">Promedio</span>
                    <div class="relative inline-block w-10 align-middle select-none">
                        <input type="checkbox" id="comparacion-toggle" class="toggle-checkbox absolute block w-5 h-5 rounded-full bg-white border-4 appearance-none cursor-pointer"/>
                        <label for="comparacion-toggle" class="toggle-label block overflow-hidden h-5 rounded-full bg-gray-300 cursor-pointer"></label>
                    </div>
                    <span class="text-[10px] font-medium text-gray-400" id="label-comp-barato">Más barato</span>
                </div>
            </div>
        </header>

        <!-- ========================================== -->
        <!-- CONTENEDOR DE TARJETAS -->
        <!-- ========================================== -->
        <main class="flex-1 overflow-y-auto p-4 pb-24 bg-gray-50" id="contenedor-productos"></main>

        <!-- BOTÓN FLOTANTE (Fix Bug: Llama a abrirModal()) -->
        <button onclick="abrirModal()" class="absolute bottom-6 right-6 bg-indigo-600 text-white w-14 h-14 rounded-full shadow-lg flex items-center justify-center hover:bg-indigo-700 transition transform hover:scale-105 z-30">
            <i class="ph ph-plus text-2xl"></i>
        </button>

        <!-- ========================================== -->
        <!-- MODAL 1: NUEVO INGRESO (Mantenido intacto) -->
        <!-- ========================================== -->
        <!-- ... [El modal de nuevo ingreso original se mantiene oculto aquí por brevedad, está en el JS generado] ... -->
        
        <div id="modal-backdrop" class="fixed inset-0 bg-black/50 z-50 hidden transition-opacity">
            <div id="modal-content" class="absolute bottom-0 left-0 right-0 bg-white rounded-t-2xl shadow-2xl p-6 modal-enter max-w-md mx-auto max-h-[90vh] overflow-y-auto">
                <div class="flex justify-between items-center mb-4 sticky top-0 bg-white pb-2 z-10 border-b">
                    <h2 class="text-lg font-bold text-gray-800">Registrar Precio</h2>
                    <button type="button" onclick="cerrarModal()" class="text-gray-400 hover:text-gray-600"><i class="ph ph-x text-xl"></i></button>
                </div>
                <form id="form-registro" onsubmit="guardarRegistro(event)" class="flex flex-col gap-4">
                    <div class="w-full flex justify-center">
                        <label id="btn-foto" for="input-foto" class="flex flex-col items-center justify-center w-full h-24 border-2 border-dashed border-gray-300 rounded-lg cursor-pointer bg-gray-50 hover:bg-gray-100 transition">
                            <div class="flex flex-col items-center justify-center pt-5 pb-6 text-gray-500">
                                <i class="ph ph-camera text-2xl mb-1"></i>
                                <p class="text-xs font-medium">Tomar o subir foto</p>
                            </div>
                            <input id="input-foto" type="file" accept="image/*" capture="environment" class="hidden" onchange="previewImagen(event, 'img-preview', 'preview-container', 'btn-foto')"/>
                        </label>
                    </div>
                    <div id="preview-container" class="hidden w-full h-32 rounded-lg bg-gray-200 overflow-hidden relative">
                        <img id="img-preview" src="" alt="Vista previa" class="w-full h-full object-cover">
                        <button type="button" onclick="quitarFoto('input-foto', 'img-preview', 'preview-container', 'btn-foto')" class="absolute top-1 right-1 bg-white rounded-full p-1 text-red-500 shadow"><i class="ph ph-trash"></i></button>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 mb-1">Nombre (Requerido)</label>
                        <input type="text" id="input-nombre" onkeyup="evaluarCategoriaEnVivo('input-nombre', 'categoria-preview')" required placeholder="Ej: Jabón Zote 400g" class="w-full border rounded-lg py-2 px-3 text-sm focus:ring-2 focus:ring-indigo-500 outline-none">
                        <div id="categoria-preview" class="text-[10px] text-indigo-500 mt-1 hidden font-medium flex items-center gap-1"></div>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 mb-1">Precio Etiqueta $ (Requerido)</label>
                        <input type="number" id="input-precio" required step="0.01" placeholder="0.00" class="w-full border rounded-lg py-2 px-3 text-sm focus:ring-2 focus:ring-indigo-500 outline-none">
                    </div>
                    <button type="submit" class="w-full bg-indigo-600 text-white font-bold py-3 rounded-xl hover:bg-indigo-700 transition shadow-md">Guardar Registro</button>
                </form>
            </div>
        </div>

        <!-- ========================================== -->
        <!-- MODAL 2: ACTUALIZACIÓN Y BUGS (Rediseñado) -->
        <!-- ========================================== -->
        <div id="modal-bug" class="fixed inset-0 bg-black/60 z-50 hidden transition-opacity backdrop-blur-sm">
            <div id="modal-bug-content" class="absolute bottom-0 left-0 right-0 bg-white rounded-t-2xl shadow-2xl p-6 modal-enter max-w-md mx-auto max-h-[90vh] overflow-y-auto">
                <div class="flex justify-between items-start mb-4 sticky top-0 bg-white pb-2 z-10 border-b">
                    <div>
                        <h2 class="text-lg font-bold text-gray-800 flex items-center gap-1"><i class="ph-fill ph-warning-circle text-amber-500"></i> Actualizar o Reportar</h2>
                        <p id="bug-prod-nombre" class="text-xs text-gray-500 line-clamp-1 mt-1 font-medium"></p>
                    </div>
                    <button type="button" onclick="cerrarModalBug()" class="text-gray-400 hover:text-gray-600 bg-gray-100 p-1.5 rounded-full">
                        <i class="ph ph-x text-lg"></i>
                    </button>
                </div>
                
                <form id="form-bug" onsubmit="guardarActualizacion(event)" class="flex flex-col gap-0 pb-4">
                    <input type="hidden" id="bug-prod-id">
                    
                    <!-- ACTUALIZACIÓN DE PRECIO -->
                    <div class="bg-indigo-50 p-4 rounded-xl border border-indigo-100 mb-4">
                        <div class="flex justify-between items-center mb-2">
                            <label class="block text-xs font-bold text-indigo-800">Nuevo Precio de Etiqueta</label>
                            <span id="bug-prod-precio-actual" class="text-[10px] text-indigo-500 font-medium bg-indigo-100 px-2 py-0.5 rounded-full">Actual: $0.00</span>
                        </div>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 transform -translate-y-1/2 text-xl font-bold text-indigo-900">$</span>
                            <input type="number" id="input-bug-precio" step="0.01" placeholder="0.00" class="w-full bg-white border-2 border-indigo-200 rounded-lg py-3 pl-10 pr-4 text-xl font-bold text-indigo-900 focus:ring-4 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none transition">
                        </div>
                    </div>

                    <!-- REPORTES SECUNDARIOS SIEMPRE VISIBLES (Sin acordeón) -->
                    <div class="flex flex-col gap-3 pt-2 border-t">
                        <h3 class="text-xs font-bold text-gray-700 uppercase tracking-wide flex items-center gap-1 mb-1"><i class="ph ph-flag"></i> Otras opciones de reporte</h3>
                        
                        <!-- 1. Foto -->
                        <div class="flex items-center gap-2">
                            <label id="btn-bug-foto" for="input-bug-foto" class="flex-1 border border-dashed border-gray-300 bg-gray-50 hover:bg-gray-100 py-2 rounded-lg text-xs font-medium text-gray-600 text-center cursor-pointer transition">
                                <i class="ph ph-camera mr-1"></i> Actualizar fotografía
                            </label>
                            <input id="input-bug-foto" type="file" accept="image/*" capture="environment" class="hidden" onchange="previewImagen(event, 'bug-img-preview', 'bug-preview-container', 'btn-bug-foto')"/>
                        </div>
                        <div id="bug-preview-container" class="hidden w-full h-24 rounded-lg bg-gray-200 overflow-hidden relative">
                            <img id="bug-img-preview" src="" alt="Vista previa" class="w-full h-full object-cover">
                            <button type="button" onclick="quitarFoto('input-bug-foto', 'bug-img-preview', 'bug-preview-container', 'btn-bug-foto')" class="absolute top-1 right-1 bg-white rounded-full p-1 text-red-500 shadow"><i class="ph ph-trash"></i></button>
                        </div>

                        <!-- 2. No encontrado -->
                        <label class="flex items-center gap-2 cursor-pointer p-2.5 rounded-lg border bg-gray-50 hover:bg-red-50 hover:border-red-200 transition">
                            <input type="checkbox" id="bug-no-encontrado" class="w-4 h-4 text-red-600 rounded border-gray-300">
                            <span class="text-xs font-medium text-gray-700">No lo encontré (Agotado/Descontinuado)</span>
                        </label>
                        
                        <!-- 3. Categoría (Con Datalist para búsqueda nativa Fricción Cero) -->
                        <div class="flex flex-col gap-1">
                            <label class="text-[10px] font-bold text-gray-500">CORREGIR CATEGORÍA SEMÁNTICA</label>
                            <input list="categorias-list" id="bug-categoria" placeholder="Buscar o elegir categoría..." class="w-full border rounded-lg py-2.5 px-3 text-xs text-gray-700 outline-none bg-gray-50 focus:ring-2 focus:ring-indigo-500">
                            <datalist id="categorias-list">
                                <!-- Se llena vía JS -->
                            </datalist>
                        </div>

                        <!-- 4. Notas Generales -->
                        <div class="flex flex-col gap-1">
                            <label class="text-[10px] font-bold text-gray-500">NOTAS / REPORTE GENÉRICO</label>
                            <textarea id="bug-notas" rows="2" placeholder="Ej. El tamaño del empaque cambió..." class="w-full border rounded-lg py-2 px-3 text-xs focus:ring-2 focus:ring-indigo-500 outline-none bg-gray-50"></textarea>
                        </div>
                    </div>

                    <!-- BOTONES DE ACCIÓN (Sticky abajo para estar siempre accesibles) -->
                    <div class="sticky bottom-0 bg-white pt-4 mt-2 border-t flex gap-2">
                        <button type="button" onclick="enviarReporteBug()" class="flex-1 bg-gray-100 text-gray-700 font-bold py-3 rounded-xl text-xs hover:bg-gray-200 transition">
                            Solo Reportar
                        </button>
                        <button type="submit" class="flex-2 w-2/3 bg-indigo-600 text-white font-bold py-3 rounded-xl hover:bg-indigo-700 transition shadow-md text-sm">
                            Confirmar
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- ========================================== -->
        <!-- MODAL PLACEHOLDER (Cambiar Ubicación) -->
        <!-- ========================================== -->
        <div id="modal-ubicacion" class="fixed inset-0 bg-black/50 z-50 hidden transition-opacity flex items-center justify-center p-4">
            <div class="bg-white rounded-2xl p-6 w-full max-w-sm shadow-2xl">
                <h3 class="font-bold text-lg mb-2">Filtro de Ubicación</h3>
                <p class="text-sm text-gray-500 mb-4">Selecciona el radio de competencia de precios.</p>
                <div class="space-y-2 mb-6">
                    <label class="flex items-center gap-2 p-2 rounded bg-indigo-50 border border-indigo-200"><input type="radio" name="loc" checked> <b>Misma Tienda</b></label>
                    <label class="flex items-center gap-2 p-2 rounded border opacity-50"><input type="radio" name="loc" disabled> Mismo C.P. (Próximamente)</label>
                    <label class="flex items-center gap-2 p-2 rounded border opacity-50"><input type="radio" name="loc" disabled> Toda la Ciudad (Próximamente)</label>
                </div>
                <button onclick="document.getElementById('modal-ubicacion').classList.add('hidden')" class="w-full bg-indigo-600 text-white font-bold py-2 rounded-lg">Cerrar</button>
            </div>
        </div>

    </div>

    <!-- ========================================== -->
    <!-- LOGICA JAVASCRIPT Y MOTOR -->
    <!-- ========================================== -->
    <script>
        // [ARQUITECTURA] Diccionarios de UI para mapear datos crudos a representaciones amigables
        const DICCIONARIO_FUENTES = {
            "scraping_api": { icono: "ph-robot", label: "Web Scraping" },
            "manual_privado": { icono: "ph-user-focus", label: "Actualizado por ti" },
            "competencia": { icono: "ph-storefront", label: "Competencia" }
        };

        const DICCIONARIO_SEMANTICO = [
            { id: "lacteos", nombre: "Lácteos y Huevo", regex: /leche|queso|yoghurt|yogur|mantequilla|crema|huevo/i, icono: "ph-egg" },
            { id: "despensa", nombre: "Despensa Básica", regex: /aceite|arroz|frijol|frijoles|az[uú]car|sal|harina|pasta|espagueti|lenteja|at[uú]n|pan/i, icono: "ph-package" },
            { id: "salsas", nombre: "Salsas y Condimentos", regex: /catsup|ketchup|mayonesa|mostaza|salsa|vinagre|pimienta|sazonador|adobo|mole/i, icono: "ph-pepper" },
            { id: "carnes", nombre: "Carnes y Embutidos", regex: /pollo|res|cerdo|tocino|salchicha|jam[oó]n|chorizo|carne/i, icono: "ph-bone" },
            { id: "frutas_verduras", nombre: "Frutas y Verduras", regex: /manzana|pl[aá]tano|tomate|jitomate|cebolla|papa|aguacate|lim[oó]n|lechuga/i, icono: "ph-apple-logo" },
            { id: "bebidas", nombre: "Bebidas", regex: /agua|refresco|jugo|caf[eé]|t[eé]|cerveza|vino|tequila/i, icono: "ph-coffee" },
            { id: "snacks", nombre: "Snacks y Dulces", regex: /papas|galletas|chocolate|cacahuates|dulces|gomitas/i, icono: "ph-cookie" },
            { id: "limpieza", nombre: "Higiene y Limpieza", regex: /detergente|cloro|suavizante|jab[oó]n|shampoo|desodorante|papel higi[eé]nico|servilletas/i, icono: "ph-drop" }
        ];

        // Poblar datalist de categorías
        const dataListCategorias = document.getElementById('categorias-list');
        DICCIONARIO_SEMANTICO.forEach(cat => {
            let opt = document.createElement('option');
            opt.value = cat.nombre;
            dataListCategorias.appendChild(opt);
        });

        // Base de Datos de Prueba (Simulando API Response)
        let datosCrudos = [
            { id: "1", nombre: "Aceite de aguacate Avocare 500 ml", precio: { actual: 160.00 }, marca: "Avocare", subtipo: "aceite de aguacate", tienda_id: "walmart_patio", url_foto: "https://images.unsplash.com/photo-1620603706093-4e443cecbdf3?w=100&h=100&fit=crop", registro_meta: { timestamp: Date.now(), origen_id: "scraping_api" } },
            { id: "2", nombre: "Catsup Heinz pouch 620 g", precio: { actual: 28.00 }, marca: "Heinz", subtipo: "catsup", tienda_id: "walmart_patio", url_foto: "https://images.unsplash.com/photo-1604325492484-934cfa593414?w=100&h=100&fit=crop", registro_meta: { timestamp: Date.now() - 100000, origen_id: "scraping_api" } },
            { id: "3", nombre: "Catsup Heinz 567 g", precio: { actual: 39.00 }, marca: "Heinz", subtipo: "catsup", tienda_id: "walmart_patio", registro_meta: { timestamp: Date.now() - 200000, origen_id: "scraping_api" } },
            { id: "4", nombre: "Ketchup Heinz 1.07 kg", precio: { actual: 54.00 }, marca: "Heinz", subtipo: "catsup", tienda_id: "walmart_patio", registro_meta: { timestamp: Date.now() - 300000, origen_id: "scraping_api" } },
            { id: "c1", nombre: "Catsup genérica 500g", precio: { actual: 15.00 }, marca: "Great Value", subtipo: "catsup", tienda_id: "competencia", registro_meta: { timestamp: Date.now(), origen_id: "competencia" } },
            { id: "c2", nombre: "Catsup Artesanal 250g", precio: { actual: 80.00 }, marca: "Gourmet", subtipo: "catsup", tienda_id: "competencia", registro_meta: { timestamp: Date.now(), origen_id: "competencia" } },
            { id: "5", nombre: "Sopa instantánea Maruchan camarón 64 g", precio: { actual: 14.50 }, marca: "Maruchan", subtipo: "sopa instantanea", tienda_id: "walmart_patio", url_foto: "https://images.unsplash.com/photo-1612929633738-8fe44f7ec841?w=100&h=100&fit=crop", registro_meta: { timestamp: Date.now(), origen_id: "scraping_api" } },
            { id: "c3", nombre: "Sopa instantánea Maruchan camarón 64 g", precio: { actual: 12.00 }, marca: "Maruchan", subtipo: "sopa instantanea", tienda_id: "competencia", registro_meta: { timestamp: Date.now(), origen_id: "competencia" } }
        ];

        // Estado Global UI
        let mostrarPrecioEstandar = false;
        let comparacionModo = 'promedio';
        let mostrarImagenes = false;
        let busquedaActual = "";
        let productosCompletos = [];

        // [FILOSOFÍA] Motor de Procesamiento y Estandarización de "Peras con Peras"
        function procesarDatos() {
            const regexTamano = /(\d+(?:\.\d+)?)\s*(ml|l|g|kg|litros|mililitros)/i;
            let productosParseados = [];
            let statsSubcategoria = {}; 

            // 1. Parseo y Extracción de Meta-Data
            datosCrudos.forEach(prod => {
                const match = prod.nombre.match(regexTamano);
                let presentacion = { valor: 1, unidad: 'u' };
                let nombreRaiz = prod.nombre;

                if (match) {
                    let valorCrudo = parseFloat(match[1]);
                    let unidadCruda = match[2].toLowerCase();
                    if (unidadCruda === 'kg') { presentacion.valor = valorCrudo * 1000; presentacion.unidad = 'g'; }
                    else if (unidadCruda === 'l' || unidadCruda === 'litros') { presentacion.valor = valorCrudo * 1000; presentacion.unidad = 'ml'; }
                    else if (unidadCruda === 'mililitros') { presentacion.valor = valorCrudo; presentacion.unidad = 'ml'; }
                    else { presentacion.valor = valorCrudo; presentacion.unidad = unidadCruda; }
                    nombreRaiz = prod.nombre.replace(match[0], '').trim().replace(/[-,\s]+$/, '');
                }

                let precioEstandar = null;
                if (presentacion.valor > 0 && (presentacion.unidad === 'g' || presentacion.unidad === 'ml')) {
                    precioEstandar = (prod.precio.actual / presentacion.valor) * 100;
                }

                let categoriaSemantica = { id: "otros", nombre: "Otros", icono: "ph-shopping-bag" };
                for (let cat of DICCIONARIO_SEMANTICO) {
                    if (cat.regex.test(prod.nombre)) { categoriaSemantica = cat; break; }
                }

                let subtipoReal = prod.subtipo ? prod.subtipo.toLowerCase() : categoriaSemantica.nombre.toLowerCase();

                const objProcesado = {
                    ...prod,
                    nombre_raiz: nombreRaiz,
                    presentacion_parseada: presentacion,
                    precio_estandar: precioEstandar,
                    unidad_estandar: presentacion.unidad === 'u' ? 'u' : '100' + presentacion.unidad,
                    subtipo_calculo: subtipoReal,
                    categoria_semantica: categoriaSemantica
                };
                productosParseados.push(objProcesado);

                // Estadísticas Agrupadas
                if (precioEstandar) {
                    if (!statsSubcategoria[subtipoReal]) {
                        statsSubcategoria[subtipoReal] = { count: 0, suma: 0, min: Infinity, max: -Infinity };
                    }
                    statsSubcategoria[subtipoReal].count += 1;
                    statsSubcategoria[subtipoReal].suma += precioEstandar;
                    if (precioEstandar < statsSubcategoria[subtipoReal].min) statsSubcategoria[subtipoReal].min = precioEstandar;
                    if (precioEstandar > statsSubcategoria[subtipoReal].max) statsSubcategoria[subtipoReal].max = precioEstandar;
                }
            });

            // 2. Aplicar Escala de Color 5 Tonos Text-Only
            return productosParseados.map(prod => {
                let colorTexto = "text-gray-900"; 
                let fontWeight = "font-bold";
                let msgPromedio = "Único Registro";
                let msgMinimo = "Único Registro";

                if (prod.precio_estandar && statsSubcategoria[prod.subtipo_calculo].count > 1) {
                    let stats = statsSubcategoria[prod.subtipo_calculo];
                    let promedio = stats.suma / stats.count;
                    let difMedia = ((prod.precio_estandar - promedio) / promedio) * 100;
                    let difMin = ((prod.precio_estandar - stats.min) / stats.min) * 100; 

                    let isMin = prod.precio_estandar === stats.min;
                    let isMax = prod.precio_estandar === stats.max;

                    if (isMin) {
                        colorTexto = "text-emerald-700"; fontWeight = "font-black";
                        msgPromedio = `Más barato en su categoría (${Math.abs(difMedia).toFixed(1)}% vs media)`;
                        msgMinimo = `🏆 Es el más barato (-${Math.abs(difMedia).toFixed(1)}% vs media)`;
                    } else if (isMax) {
                        colorTexto = "text-rose-700"; fontWeight = "font-black";
                        msgPromedio = `Más caro en su categoría (+${difMedia.toFixed(1)}% vs media)`;
                        msgMinimo = `El más caro (+${difMin.toFixed(1)}% vs el más barato)`;
                    } else if (difMedia <= 0) {
                        colorTexto = "text-emerald-500"; fontWeight = "font-bold";
                        msgPromedio = `${Math.abs(difMedia).toFixed(1)}% abajo de la media`;
                        msgMinimo = `+${difMin.toFixed(1)}% vs el más barato`;
                    } else {
                        colorTexto = "text-rose-500"; fontWeight = "font-bold";
                        msgPromedio = `${difMedia.toFixed(1)}% arriba de la media`;
                        msgMinimo = `+${difMin.toFixed(1)}% vs el más barato`;
                    }
                }
                return { ...prod, colorTexto, fontWeight, msgPromedio, msgMinimo };
            });
        }

        // ==========================================
        // RENDERIZADO
        // ==========================================
        function actualizarDatos() {
            productosCompletos = procesarDatos();
            renderizarTarjetas();
        }

        function renderizarTarjetas() {
            const contenedor = document.getElementById('contenedor-productos');
            contenedor.innerHTML = '';

            const filtrados = productosCompletos.filter(p => 
                (p.tienda_id === "walmart_patio" || !p.tienda_id) && 
                (p.nombre_raiz.toLowerCase().includes(busquedaActual.toLowerCase()) || 
                (p.marca && p.marca.toLowerCase().includes(busquedaActual.toLowerCase())))
            );

            if (filtrados.length === 0) {
                contenedor.innerHTML = `<div class="text-center text-gray-400 mt-10"><i class="ph ph-magnifying-glass text-4xl mb-2"></i><p>No se encontraron productos.</p></div>`;
                return;
            }

            filtrados.forEach(prod => {
                const precioPrincipal = mostrarPrecioEstandar && prod.precio_estandar 
                    ? `$${prod.precio_estandar.toFixed(2)}` 
                    : `$${prod.precio.actual.toFixed(2)}`;
                
                const sufijoPrecio = mostrarPrecioEstandar && prod.precio_estandar 
                    ? `/ ${prod.unidad_estandar}` 
                    : `Etiqueta`;

                const leyendaCalculada = comparacionModo === 'promedio' ? prod.msgPromedio : prod.msgMinimo;
                
                const imgHtml = (mostrarImagenes && prod.url_foto) 
                    ? `<img src="${prod.url_foto}" class="w-12 h-12 rounded object-cover border shrink-0">` 
                    : '';

                const card = document.createElement('div');
                card.className = "bg-white p-4 rounded-xl shadow-sm border border-gray-100 mb-3 flex flex-col gap-3 relative";
                
                card.innerHTML = `
                    <div class="flex justify-between items-start gap-3">
                        ${imgHtml}
                        <div class="flex-1">
                            <div class="flex items-center gap-1 mb-1">
                                <span class="text-[9px] font-bold uppercase text-gray-400 tracking-wider flex items-center gap-1">
                                    <i class="ph ${prod.categoria_semantica.icono}"></i> ${prod.categoria_semantica.nombre}
                                </span>
                            </div>
                            <h3 class="font-bold text-gray-800 leading-tight text-sm">${prod.nombre_raiz}</h3>
                            <div class="flex items-center gap-2 mt-1">
                                <span class="text-xs text-gray-500">${prod.marca || ''}</span>
                                <span class="text-[10px] font-mono bg-gray-100 px-1.5 py-0.5 rounded text-gray-600 border border-gray-200">${prod.presentacion_parseada.valor}${prod.presentacion_parseada.unidad}</span>
                            </div>
                        </div>
                        <div class="text-right flex flex-col items-end shrink-0 pt-1">
                            <div class="${prod.colorTexto} ${prod.fontWeight} text-2xl leading-none tracking-tight">${precioPrincipal}</div>
                            <div class="text-[9px] uppercase tracking-wide text-gray-400 mt-1 font-bold">${sufijoPrecio}</div>
                        </div>
                    </div>
                    
                    <div class="flex justify-between items-end border-t border-gray-50 pt-2 mt-1">
                        <div class="flex items-center gap-1 text-[10px] bg-gray-50 text-gray-500 px-2 py-1 rounded-full font-medium">
                            <i class="ph ${DICCIONARIO_FUENTES[prod.registro_meta.origen_id]?.icono || 'ph-info'}"></i> 
                            ${DICCIONARIO_FUENTES[prod.registro_meta.origen_id]?.label || 'Dato'}
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="text-[10px] font-bold ${prod.colorTexto} bg-gray-50 px-2 py-1 rounded">${leyendaCalculada}</span>
                            <button onclick="abrirModalBug('${prod.id}')" class="bg-amber-100 text-amber-600 hover:bg-amber-200 p-1.5 rounded-full transition shadow-sm border border-amber-200">
                                <i class="ph-bold ph-warning text-sm"></i>
                            </button>
                        </div>
                    </div>
                `;
                contenedor.appendChild(card);
            });
        }

        // ==========================================
        // CONTROLADORES DE INTERACCIÓN
        // ==========================================
        document.getElementById('buscador').addEventListener('input', (e) => {
            busquedaActual = e.target.value; renderizarTarjetas();
        });

        function toggleImagenes() {
            mostrarImagenes = !mostrarImagenes;
            const btn = document.getElementById('btn-toggle-img');
            btn.className = mostrarImagenes 
                ? "p-2 rounded-full transition text-indigo-600 bg-indigo-50"
                : "p-2 rounded-full transition text-gray-400 hover:text-indigo-600 hover:bg-indigo-50";
            renderizarTarjetas();
        }

        document.getElementById('price-toggle').addEventListener('change', (e) => {
            mostrarPrecioEstandar = e.target.checked;
            document.getElementById('label-unidad').className = mostrarPrecioEstandar ? 'text-[10px] font-bold text-indigo-600' : 'text-[10px] font-medium text-gray-400';
            document.getElementById('label-etiqueta').className = mostrarPrecioEstandar ? 'text-[10px] font-medium text-gray-400' : 'text-[10px] font-bold text-indigo-600';
            renderizarTarjetas();
        });

        document.getElementById('comparacion-toggle').addEventListener('change', (e) => {
            comparacionModo = e.target.checked ? 'minimo' : 'promedio';
            document.getElementById('label-comp-barato').className = e.target.checked ? 'text-[10px] font-bold text-indigo-600' : 'text-[10px] font-medium text-gray-400';
            document.getElementById('label-comp-promedio').className = e.target.checked ? 'text-[10px] font-medium text-gray-400' : 'text-[10px] font-bold text-indigo-600';
            renderizarTarjetas();
        });

        function obtenerCategoriaSemantica(nombre) {
            for (let cat of DICCIONARIO_SEMANTICO) {
                if (cat.regex.test(nombre)) return cat;
            }
            return { id: "otros", nombre: "Otros", icono: "ph-shopping-bag" };
        }

        function evaluarCategoriaEnVivo(inputId, previewId) {
            const nombre = document.getElementById(inputId).value;
            const preview = document.getElementById(previewId);
            if (nombre.length > 3) {
                const cat = obtenerCategoriaSemantica(nombre);
                preview.innerHTML = `<i class="ph ${cat.icono}"></i> Detectado: ${cat.nombre}`;
                preview.classList.remove('hidden');
            } else {
                preview.classList.add('hidden');
            }
        }

        // Utilidad común para manejo de fotos (Sirve para modal Nuevo y modal Bug)
        function previewImagen(event, imgId, containerId, btnId) {
            const input = event.target;
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById(imgId).src = e.target.result;
                    document.getElementById(containerId).classList.remove('hidden');
                    document.getElementById(btnId).classList.add('hidden');
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        function quitarFoto(inputId, imgId, containerId, btnId) {
            document.getElementById(inputId).value = '';
            document.getElementById(imgId).src = '';
            document.getElementById(containerId).classList.add('hidden');
            document.getElementById(btnId).classList.remove('hidden');
        }

        // Modal Nuevo
        function abrirModal() {
            document.getElementById('modal-backdrop').classList.remove('hidden');
            setTimeout(() => {
                document.getElementById('modal-content').classList.replace('modal-enter', 'modal-enter-active');
            }, 10);
            document.getElementById('input-nombre').focus();
        }

        function cerrarModal() {
            document.getElementById('modal-content').classList.replace('modal-enter-active', 'modal-leave-active');
            setTimeout(() => {
                document.getElementById('modal-backdrop').classList.add('hidden');
                document.getElementById('modal-content').classList.replace('modal-leave-active', 'modal-enter');
                document.getElementById('form-registro').reset();
                quitarFoto('input-foto', 'img-preview', 'preview-container', 'btn-foto');
            }, 200);
        }

        // Modal Bug / Update
        function abrirModalBug(idProducto) {
            const prod = datosCrudos.find(p => p.id === idProducto);
            if(!prod) return;
            document.getElementById('bug-prod-id').value = prod.id;
            document.getElementById('bug-prod-nombre').textContent = `${prod.nombre} (${prod.marca || ''})`;
            document.getElementById('bug-prod-precio-actual').textContent = `Actual: $${prod.precio.actual.toFixed(2)}`;
            
            document.getElementById('modal-bug').classList.remove('hidden');
            setTimeout(() => { document.getElementById('modal-bug-content').classList.replace('modal-enter', 'modal-enter-active'); }, 10);
            document.getElementById('input-bug-precio').focus();
        }

        function cerrarModalBug() {
            document.getElementById('modal-bug-content').classList.replace('modal-enter-active', 'modal-leave-active');
            setTimeout(() => {
                document.getElementById('modal-bug').classList.add('hidden');
                document.getElementById('modal-bug-content').classList.replace('modal-leave-active', 'modal-enter');
                document.getElementById('form-bug').reset();
                quitarFoto('input-bug-foto', 'bug-img-preview', 'bug-preview-container', 'btn-bug-foto');
            }, 200);
        }

        // Guardados
        function guardarRegistro(e) {
            e.preventDefault();
            const nombre = document.getElementById('input-nombre').value;
            const precio = parseFloat(document.getElementById('input-precio').value);
            const fotoInput = document.getElementById('input-foto').files[0];

            let objMeta = { timestamp: Date.now(), origen_id: "manual_privado" };
            if (fotoInput) objMeta.tiene_foto = true;

            datosCrudos.unshift({ id: Date.now().toString(), nombre: nombre, precio: { actual: precio }, marca: "Desconocida", tienda_id: "walmart_patio", registro_meta: objMeta });
            actualizarDatos();
            cerrarModal();
        }

        function guardarActualizacion(e) {
            e.preventDefault();
            const idBase = document.getElementById('bug-prod-id').value;
            const nuevoPrecioInput = document.getElementById('input-bug-precio').value;
            if(!nuevoPrecioInput) return;
            
            const prodBase = datosCrudos.find(p => p.id === idBase);
            const prodActualizado = { ...prodBase, id: Date.now().toString(), precio: { actual: parseFloat(nuevoPrecioInput) }, registro_meta: { timestamp: Date.now(), origen_id: "manual_privado" } };
            
            // Reemplazar la foto si subió una nueva
            if (document.getElementById('input-bug-foto').files[0]) {
                prodActualizado.url_foto = document.getElementById('bug-img-preview').src; // Simulando carga
            }

            datosCrudos.unshift(prodActualizado);
            enviarReporteBugSecundario();
            actualizarDatos();
            cerrarModalBug();
        }

        function enviarReporteBug() {
            enviarReporteBugSecundario();
            cerrarModalBug();
            alert("Reporte enviado. ¡Gracias!"); 
        }

        function enviarReporteBugSecundario() {
            const noEncontrado = document.getElementById('bug-no-encontrado').checked;
            const catInco = document.getElementById('bug-categoria').value;
            const notas = document.getElementById('bug-notas').value;
            if (noEncontrado || catInco || notas) { console.log("Auditoría enviada:", { noEncontrado, catInco, notas }); }
        }

        function abrirModalUbicacion() {
            document.getElementById('modal-ubicacion').classList.remove('hidden');
        }

        actualizarDatos();
    </script>
</body>
</html>
